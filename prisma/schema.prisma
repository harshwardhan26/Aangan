// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Property {
  id           String   @id @default(cuid())
  title        String
  price        Int
  displayPrice String
  location     String
  bedrooms     Int
  areaSqft     Int
  imageUrl     String
  badge        String?
  amenities    String?
  description  String?
  propertyType String?
  purpose      String?
  sellerId     String?
  seller       User?    @relation(fields: [sellerId], references: [id])
  leads        Lead[]
  savedBy      SavedProperty[]
  images       PropertyImage[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([location])
  @@index([price])
  @@index([bedrooms])
  @@index([propertyType])
}

model User {
  id            String    @id @default(cuid())
  phone         String?   @unique
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("buyer")
  isVerified    Boolean   @default(true)
  properties      Property[]
  sellerLeads     Lead[]          @relation("SellerLeads")
  buyerLeads      Lead[]          @relation("BuyerLeads")
  savedProperties SavedProperty[]
  accounts        Account[]
  sessions        Session[]
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model OtpToken {
  id        String   @id @default(cuid())
  phone     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Lead {
  id         String   @id @default(cuid())
  name       String
  phone      String
  email      String?
  propertyId String
  sellerId   String
  status     String   @default("New")
  buyerId      String?
  source       String    @default("contact")
  stage        String    @default("New Lead")
  notes        String?
  followupDate DateTime?
  clientBudget Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  property   Property @relation(fields: [propertyId], references: [id])
  seller     User     @relation("SellerLeads", fields: [sellerId], references: [id])
  buyer      User?    @relation("BuyerLeads", fields: [buyerId], references: [id])
}

model SavedProperty {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@unique([userId, propertyId])
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  propertyId String
  createdAt  DateTime @default(now())

  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
